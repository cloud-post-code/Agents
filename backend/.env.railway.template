# Railway Environment Variables Template
# Copy these to Railway Dashboard → Your Project → Variables

# ============================================
# PostgreSQL (Automatically provided by Railway)
# ============================================
# These are set automatically when you add PostgreSQL:
# PGHOST=<auto-generated>.railway.app
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=<auto-generated>
# PGDATABASE=railway

# ============================================
# Application Settings (Set Manually)
# ============================================

# Environment
APP_ENV=production
DEBUG=false

# Security - IMPORTANT: Generate a secure random key!
# Use: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_64_CHARS

# CORS - Your frontend URL(s), comma-separated
# Example: https://artisan-frontend.railway.app
CORS_ORIGINS=https://your-frontend-url.railway.app

# ============================================
# OpenAI API (Required for Product Ingestion)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Redis (Optional - automatically provided if you add Redis service)
# ============================================
# REDIS_URL is set automatically by Railway if you add Redis
# If using external Redis:
# REDIS_URL=redis://user:password@host:port/0

# ============================================
# Optional Settings
# ============================================

# JWT Settings (defaults are fine, but you can override)
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_DAYS=7

# ============================================
# How to Set These in Railway
# ============================================
# 1. Go to Railway Dashboard
# 2. Select your project
# 3. Click on your backend service
# 4. Go to "Variables" tab
# 5. Click "New Variable"
# 6. Add each variable above (except PostgreSQL ones - those are auto-set)
# 7. Click "Deploy" to apply changes

# ============================================
# Generating SECRET_KEY
# ============================================
# Run this command to generate a secure key:
# openssl rand -hex 32
# 
# Or in Python:
# python -c "import secrets; print(secrets.token_hex(32))"
